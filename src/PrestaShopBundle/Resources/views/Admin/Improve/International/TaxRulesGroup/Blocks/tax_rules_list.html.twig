<div id="tax-rules-list-container"
     class="mt-3"
     data-list-url="{{ path('admin_tax_rules_list', {taxRulesGroupId: taxRulesGroupId}) }}"
     data-create-url="{{ path('admin_tax_rules_create', {taxRulesGroupId: taxRulesGroupId}) }}"
>
  <div id="tax-rules-loading">
    <div class="loading-label">{{ 'Loading tax rules'|trans({}, 'Admin.International.Feature') }}</div>
    <div class="spinner spinner-primary"></div>
  </div>
  <table class="table" id="tax-rules-list-table">
    <thead class="thead-default">
    <tr>
      <th>{{ 'Country'|trans({}, 'Admin.Global') }}</th>
      <th>{{ 'State'|trans({}, 'Admin.Global') }}</th>
      <th>{{ 'Zip/Postal code'|trans({}, 'Admin.International.Feature') }}</th>
      <th>{{ 'Behavior'|trans({}, 'Admin.International.Feature') }}</th>
      <th>{{ 'Tax'|trans({}, 'Admin.Global') }}</th>
      <th>{{ 'Rate'|trans({}, 'Admin.Global') }}</th>
      <th>{{ 'Description'|trans({}, 'Admin.Global') }}</th>
      <th></th>
      <th></th>
    </tr>
    </thead>
    <tbody>
    {# rows dynamically generated by JavaScript #}
    </tbody>
  </table>
  <div class="row justify-content-center" id="tax-rules-pagination">
    {{ include('@PrestaShop/Admin/Common/javascript_pagination.html.twig', {
      limit: 10,
      limitChoices: [10, 20, 50, 100],
    }) }}
  </div>
  <script type="text/html" id="tax-rule-tr-template">
    <tr>
      <td class="tax-rule-country"></td>
      <td class="tax-rule-state"></td>
      <td class="tax-rule-zipcode"></td>
      <td class="tax-rule-behavior"></td>
      <td class="tax-rule-tax-name"></td>
      <td class="tax-rule-tax-rate"></td>
      <td class="tax-rule-description"></td>
      <td>
        <button
          type="button"
          title="{{ 'Edit'|trans({}, 'Admin.Actions') }}"
          class="js-edit-tax-rule-btn btn tooltip-link"
          data-modal-title="{{ 'Edit tax rule'|trans({}, 'Admin.International.Feature') }}"
          data-confirm-button-label="{{ 'Save'|trans({}, 'Admin.Actions') }}"
          data-cancel-button-label="{{ 'Cancel'|trans({}, 'Admin.Actions') }}"
        >
          <i class="material-icons">edit</i>
        </button>
      </td>
      <td>
        <button
          type="button"
          title="{{ 'Delete'|trans({}, 'Admin.Actions') }}"
          class="js-delete-tax-rule-btn btn tooltip-link"
          data-confirm-title="{{ 'Tax rule deletion'|trans({}, 'Admin.International.Feature') }}"
          data-confirm-message="{{ 'Are you sure you want to delete this tax rule?'|trans({}, 'Admin.International.Feature') }}"
          data-confirm-btn-label="{{ 'Delete'|trans({}, 'Admin.Actions') }}"
          data-cancel-btn-label="{{ 'Cancel'|trans({}, 'Admin.Actions') }}"
          data-confirm-btn-class="btn-danger"
        ><i class="material-icons">delete</i>
        </button>
      </td>
    </tr>
  </script>
</div>
